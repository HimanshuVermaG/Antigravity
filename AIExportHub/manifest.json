    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*"
      ],
      "js": [
        "content.883ade9e.js"
      ],
      "run_at": "document_start",
      "css": []
    }
  ],
  "default_locale": "en",
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
