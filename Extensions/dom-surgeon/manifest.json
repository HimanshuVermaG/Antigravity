{
  "manifest_version": 3,
  "name": "DOM Surgeon",
  "version": "1.0.0",
  "description": "Visually select, edit, and manage DOM elements on any website. Delete, resize, and customize with persistent changes.",
  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "alarms"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/selector-engine.js",
        "lib/storage.js",
        "lib/history.js",
        "content/toast.js",
        "content/selector.js",
        "content/editor-panel.js",
        "content/breadcrumb.js",
        "content/widget.js",
        "content/change-sidebar.js",
        "content/multi-select.js",
        "content/box-model.js",
        "content/smart-suggestions.js",
        "content/shortcut-overlay.js",
        "content/main.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": ["<all_urls>"],
      "js": [
        "lib/storage.js",
        "content/early-hider.js"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "commands": {
    "toggle-selector": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Toggle element selector mode"
    }
  }
}
